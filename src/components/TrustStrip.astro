---

<section class="trust-strip" aria-label="Technology partners and compliance">

  <!-- Label row -->
  <div class="trust-header container">
    <span class="trust-label">Aligned with</span>
    <div class="trust-acsc">
      <span class="trust-acsc-dot" aria-hidden="true"></span>
      ACSC Essential Eight Aligned
    </div>
  </div>

  <!-- Marquee -->
  <div class="trust-marquee-wrap" aria-hidden="true">
    <div class="trust-track">

      <!-- Set A -->
      {logos.map(logo => (
        <div class="trust-item" title={logo.name}>
          <div class="trust-inner">
            <Fragment set:html={logo.svg} />
            <span class="trust-name" style={`color:${logo.color}`}>{logo.name}</span>
          </div>
        </div>
      ))}

      <!-- Set B — duplicate for seamless loop -->
      {logos.map(logo => (
        <div class="trust-item" title={logo.name}>
          <div class="trust-inner">
            <Fragment set:html={logo.svg} />
            <span class="trust-name" style={`color:${logo.color}`}>{logo.name}</span>
          </div>
        </div>
      ))}

    </div>
  </div>

</section>

<style>
  /* ── Section shell ─────────────────────────────────────── */
  .trust-strip {
    background: var(--off-white);
    padding: 32px 0 28px;
    border-bottom: 1px solid var(--mist);
    overflow: hidden;
  }

  /* ── Header row ────────────────────────────────────────── */
  .trust-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }
  .trust-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-muted);
  }
  .trust-acsc {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    background: rgba(12,27,58,0.06);
    font-size: 12px; font-weight: 600; color: var(--navy);
  }
  .trust-acsc-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green); flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  /* ── Marquee wrapper — fade edges ──────────────────────── */
  .trust-marquee-wrap {
    position: relative;
    overflow: hidden;
    /* Fade left & right edges with mask */
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  /* ── Track — CSS-only infinite scroll ─────────────────── */
  .trust-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marqueeScroll 28s linear infinite;
  }
  .trust-track:hover { animation-play-state: paused; }

  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Individual logo card ──────────────────────────────── */
  .trust-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 40px;
    border-right: 1px solid var(--mist);
    transition: background 0.2s;
    flex-shrink: 0;
    cursor: default;
  }
  .trust-item:hover { background: var(--white); }

  /* Inner: grayscale → colour on hover */
  .trust-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0.4;
    filter: grayscale(1);
    transition: opacity 0.3s var(--ease), filter 0.3s var(--ease);
    pointer-events: none;
  }
  .trust-item:hover .trust-inner {
    opacity: 1;
    filter: grayscale(0);
  }

  /* SVG sizing — enforce display block */
  .trust-inner :global(svg) {
    display: block;
    flex-shrink: 0;
  }

  .trust-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .trust-header { padding: 0 24px; }
    .trust-item   { padding: 10px 28px; }
    .trust-name   { font-size: 13px; }
  }
</style>
