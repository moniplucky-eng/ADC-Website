---
/* Hero.astro
   21st.dev pattern: full-viewport split hero — text left, floating UI card right.
   Particle mesh canvas + radial amber glow + subtle grid overlay.
   Arc SVG transitions to the off-white section below.
*/
---

<section class="hero" id="hero">

  <!-- Background layers -->
  <div class="hero-bg" aria-hidden="true">
    <!-- Faint city photo texture -->
    <div class="hero-bg-photo"></div>
    <!-- Particle canvas (JS-driven) -->
    <canvas class="hero-particles" id="heroParticles"></canvas>
    <!-- Radial amber glow, top-right -->
    <div class="hero-glow"></div>
    <!-- Subtle dot grid -->
    <div class="hero-grid"></div>
  </div>

  <!-- Curved arc transition -->
  <svg class="hero-arc" viewBox="0 0 1440 80" fill="none"
       xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 80 C360 20 1080 20 1440 80 L1440 80 L0 80 Z" fill="#F8F6F1"/>
  </svg>

  <div class="container">
    <div class="hero-inner">

      <!-- ── Left: Content ── -->
      <div class="hero-content">
        <!-- Eyebrow pill -->
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot" aria-hidden="true"></span>
          Australian-Owned &amp; Hosted
        </div>

        <h1 class="hero-title">
          Technology that<br/><em>just works</em><br/>for your business.
        </h1>

        <p class="hero-body">
          From ABN to AI — Australia Digital Centre gives small businesses the full-stack
          digital foundation they need to grow with confidence. Local expertise,
          Australian servers, zero complexity.
        </p>

        <div class="hero-actions">
          <a href="#contact"  class="btn btn-primary">Get Your Free Audit</a>
          <a href="#packages" class="btn btn-ghost-amber">See Packages</a>
        </div>

        <!-- Stats row -->
        <div class="hero-stats" aria-label="Key statistics">
          <div class="hero-stat">
            <div class="hero-stat-num">100%</div>
            <div class="hero-stat-label">Australian hosted</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">24/7</div>
            <div class="hero-stat-label">Endpoint monitoring</div>
          </div>
          <div class="hero-stat">
            <div class="hero-stat-num">1–20</div>
            <div class="hero-stat-label">Employee focus</div>
          </div>
        </div>
      </div>

      <!-- ── Right: Floating UI card ── -->
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-card-stack">

          <!-- Shadow card behind -->
          <div class="hero-card-behind"></div>

          <!-- Main dashboard card -->
          <div class="hero-card hero-card-main">
            <div class="card-header">
              <div class="card-icon">
                <svg viewBox="0 0 20 20" fill="none">
                  <rect x="2" y="3" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M7 17h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <div class="card-title">Digital Health Score</div>
                <div class="card-sub">Updated live</div>
              </div>
            </div>

            <div class="card-metric">
              87<span class="card-metric-denom">/100</span>
            </div>
            <div class="card-metric-label">Your business is well protected</div>

            <div class="card-progress">
              <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width:87%"></div>
              </div>
              <div class="progress-label">
                <span>Security</span><span>87%</span>
              </div>
            </div>

            <div class="card-pills">
              <span class="card-pill active">MFA ✓</span>
              <span class="card-pill active">Backups ✓</span>
              <span class="card-pill active">Monitoring ✓</span>
              <span class="card-pill">AI Ready</span>
            </div>
          </div>

          <!-- Floating badge 1 — ACSC -->
          <div class="floating-badge badge-1">
            <div class="floating-badge-icon">
              <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
                <path d="M8 1L9.5 6H14L10.5 9L12 14L8 11L4 14L5.5 9L2 6H6.5L8 1Z" fill="#F59B00"/>
              </svg>
            </div>
            <div>
              <div class="floating-badge-text">ACSC Compliant</div>
              <div class="floating-badge-sub">Essential Eight Phase 1</div>
            </div>
          </div>

          <!-- Floating badge 2 — SLA -->
          <div class="floating-badge badge-2">
            <div class="floating-badge-icon">
              <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
                <circle cx="8" cy="8" r="6" stroke="#F59B00" stroke-width="1.5"/>
                <path d="M8 5v3l2 1" stroke="#F59B00" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="floating-badge-text">4-hr Response SLA</div>
              <div class="floating-badge-sub">Priority helpdesk access</div>
            </div>
          </div>

        </div>
      </div>
      <!-- /.hero-visual -->

    </div>
  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 120px 0 100px;
  }

  /* ── Background layers ─────────────────────────────────── */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; }

  .hero-bg-photo {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1800&auto=format&q=60');
    background-size: cover; background-position: center top;
    opacity: 0.07;
  }
  .hero-particles {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    z-index: 1;
  }
  .hero-glow {
    position: absolute; top: -20%; right: -10%;
    width: 70vw; height: 70vw;
    max-width: 800px; max-height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,155,0,0.18) 0%, transparent 70%);
    animation: glowPulse 6s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.7; transform: scale(1.08); }
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  /* Arc SVG bottom transition */
  .hero-arc {
    position: absolute; bottom: -2px; left: 0; right: 0;
    width: 100%; height: 80px;
    z-index: 2;
  }

  /* ── Inner two-column grid ─────────────────────────────── */
  .hero-inner {
    position: relative; z-index: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* ── Left: content ─────────────────────────────────────── */
  .hero-content { max-width: 540px; }

  /* Eyebrow pill */
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(245,155,0,0.15);
    border: 1px solid rgba(245,155,0,0.3);
    border-radius: var(--radius-pill);
    padding: 6px 16px;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--amber); margin-bottom: 28px;
  }
  .hero-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--green); animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  /* Headline */
  .hero-title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1.07; color: var(--white);
    margin-bottom: 24px;
  }
  .hero-title em { font-style: italic; color: var(--amber); }

  /* Body */
  .hero-body {
    font-size: 18px; line-height: 1.7;
    color: rgba(255,255,255,0.65);
    margin-bottom: 40px; max-width: 480px;
  }

  /* CTA row */
  .hero-actions {
    display: flex; align-items: center;
    gap: 16px; flex-wrap: wrap;
  }

  /* Stats row */
  .hero-stats {
    display: flex; gap: 40px;
    margin-top: 56px; padding-top: 48px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .hero-stat-num {
    font-family: var(--font-display); font-weight: 700;
    font-size: 32px; color: var(--amber); line-height: 1;
  }
  .hero-stat-label {
    font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 4px;
  }

  /* ── Right: card stack ─────────────────────────────────── */
  .hero-visual {
    position: relative;
    display: flex; justify-content: center;
  }
  .hero-card-stack {
    position: relative; width: 100%; max-width: 420px;
  }

  /* Glass card */
  .hero-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px; padding: 28px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .hero-card-main {
    position: relative; z-index: 2;
    /* Shimmer sweep */
    overflow: hidden;
  }
  .hero-card-main::after {
    content: '';
    position: absolute; inset: 0;
    border-radius: 20px;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.04) 50%, transparent 60%);
    background-size: 200% 100%;
    animation: cardShimmer 4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes cardShimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Shadow card offset behind */
  .hero-card-behind {
    position: absolute; top: 16px; left: -16px; right: 16px; bottom: -16px;
    z-index: 1;
    background: rgba(245,155,0,0.12);
    border: 1px solid rgba(245,155,0,0.2);
    border-radius: 20px;
  }

  /* Card internals */
  .card-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
  }
  .card-icon {
    width: 40px; height: 40px; border-radius: 12px;
    background: rgba(245,155,0,0.2);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .card-icon svg { width: 20px; height: 20px; color: var(--amber); }
  .card-title { font-size: 15px; font-weight: 600; color: var(--white); }
  .card-sub   { font-size: 12px; color: rgba(255,255,255,0.4); }

  .card-metric {
    font-family: var(--font-display); font-size: 36px; font-weight: 700;
    color: var(--white);
  }
  .card-metric-denom { font-size: 20px; opacity: 0.4; }
  .card-metric-label { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 4px; }

  .card-progress { margin-top: 20px; }
  .progress-bar-bg {
    height: 6px; background: rgba(255,255,255,0.1);
    border-radius: 3px; overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%; border-radius: 3px; background: var(--amber);
    animation: grow 1.5s 0.5s both var(--ease);
  }
  @keyframes grow { from { width: 0; } }
  .progress-label {
    display: flex; justify-content: space-between;
    font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 8px;
  }

  .card-pills { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px; }
  .card-pill {
    padding: 5px 12px; border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.08);
    font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.6);
  }
  .card-pill.active { background: rgba(245,155,0,0.2); color: var(--amber); }

  /* ── Floating badges ───────────────────────────────────── */
  .floating-badge {
    position: absolute; background: var(--white);
    border-radius: 14px; padding: 10px 16px;
    box-shadow: 0 8px 32px rgba(12,27,58,0.2);
    display: flex; align-items: center; gap: 8px;
    z-index: 4;
  }
  .floating-badge-icon {
    width: 28px; height: 28px; border-radius: 8px;
    background: var(--amber-pale);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .floating-badge-text { font-size: 12px; font-weight: 600; color: var(--navy); }
  .floating-badge-sub  { font-size: 10px; color: var(--text-muted); }

  .badge-1 { bottom: -24px; right: -32px; animation: float1 4s ease-in-out infinite; }
  .badge-2 { top: -20px;   left: -28px;  animation: float2 5s 1s ease-in-out infinite; }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; gap: 60px; }
    .hero-visual { display: none; }
  }
  @media (max-width: 768px) {
    .hero { padding: 100px 0 80px; }
    .hero-stats { gap: 24px; }
  }
  @media (max-width: 480px) {
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .hero-stats   { flex-direction: column; gap: 20px; }
  }
</style>

<script>
  /* ── Particle mesh canvas ─────────────────────────────── */
  const canvas = document.getElementById('heroParticles') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let animId: number;

    const resize = () => {
      canvas.width  = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    class Particle {
      x!: number; y!: number; r!: number;
      vx!: number; vy!: number; alpha!: number;
      life!: number; maxLife!: number;

      constructor() { this.reset(true); }
      reset(init: boolean) {
        this.x       = Math.random() * canvas.width;
        this.y       = init ? Math.random() * canvas.height : canvas.height + 10;
        this.r       = Math.random() * 1.5 + 0.3;
        this.vx      = (Math.random() - 0.5) * 0.3;
        this.vy      = -(Math.random() * 0.4 + 0.15);
        this.alpha   = Math.random() * 0.5 + 0.1;
        this.life    = 0;
        this.maxLife = Math.random() * 300 + 200;
      }
      update() {
        this.x += this.vx; this.y += this.vy; this.life++;
        if (this.life > this.maxLife || this.y < -10) this.reset(false);
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(245,155,0,${this.alpha * Math.sin(Math.PI * this.life / this.maxLife)})`;
        ctx.fill();
      }
    }

    const particles: Particle[] = Array.from({ length: 80 }, () => new Particle());

    const drawLines = () => {
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 100) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(245,155,0,${0.06 * (1 - dist / 100)})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
    };

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      drawLines();
      particles.forEach(p => { p.update(); p.draw(); });
      animId = requestAnimationFrame(animate);
    };
    animate();

    /* Pause when out of view (performance) */
    const heroEl = document.getElementById('hero');
    if (heroEl) {
      new IntersectionObserver(([e]) => {
        if (e.isIntersecting) animate(); else cancelAnimationFrame(animId);
      }).observe(heroEl);
    }
  }

  /* ── 3D tilt on hero card ─────────────────────────────── */
  const card = document.querySelector('.hero-card-main') as HTMLElement | null;
  card?.addEventListener('mousemove', e => {
    const r  = card.getBoundingClientRect();
    const dx = (e.clientX - (r.left + r.width  / 2)) / (r.width  / 2);
    const dy = (e.clientY - (r.top  + r.height / 2)) / (r.height / 2);
    card.style.transform = `perspective(800px) rotateY(${dx * 5}deg) rotateX(${-dy * 4}deg) translateY(-3px)`;
  });
  card?.addEventListener('mouseleave', () => { card.style.transform = ''; });

  /* ── Magnetic CTA buttons ─────────────────────────────── */
  document.querySelectorAll<HTMLElement>('.btn-primary').forEach(btn => {
    btn.addEventListener('mousemove', e => {
      const r  = btn.getBoundingClientRect();
      const dx = e.clientX - (r.left + r.width  / 2);
      const dy = e.clientY - (r.top  + r.height / 2);
      btn.style.transform = `translate(${dx * 0.18}px, ${dy * 0.18}px)`;
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = '';
      btn.style.transition = 'transform 0.4s var(--ease)';
      setTimeout(() => { btn.style.transition = ''; }, 400);
    });
  });
</script>
