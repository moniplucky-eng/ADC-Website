---
/* ChatBot.astro
   21st.dev pattern: fixed-position FAB + slide-up chat panel.
   Rule-based decision tree via quick-reply buttons — no free-text
   input needed. Typing indicator, bot/user bubble layout, amber accents.
*/
---

<!-- FAB trigger -->
<button
  class="chat-fab"
  id="chatFab"
  aria-label="Open chat"
  aria-expanded="false"
  aria-controls="chatPanel"
>
  <!-- Chat icon (default) -->
  <svg class="fab-icon fab-icon--chat" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
          stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round"/>
  </svg>
  <!-- Close icon (when open) -->
  <svg class="fab-icon fab-icon--close" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2"
          stroke-linecap="round"/>
  </svg>
  <!-- Notification dot -->
  <span class="chat-fab-dot" aria-hidden="true"></span>
</button>

<!-- Chat panel -->
<div class="chat-panel" id="chatPanel" role="dialog" aria-label="ADC Chat Assistant" aria-hidden="true">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-avatar" aria-hidden="true">
      <svg viewBox="0 0 36 36" fill="none">
        <rect width="36" height="36" rx="10" fill="#3232C8"/>
        <rect x="8" y="8" width="8" height="8" rx="1.5" fill="#F59B00"/>
        <rect x="20" y="8" width="8" height="8" rx="1.5" fill="#F59B00"/>
        <rect x="8" y="20" width="8" height="8" rx="1.5" fill="rgba(245,155,0,0.5)"/>
        <rect x="20" y="20" width="8" height="8" rx="1.5" fill="rgba(245,155,0,0.3)"/>
      </svg>
    </div>
    <div class="chat-header-info">
      <div class="chat-header-name">ADC Assistant</div>
      <div class="chat-header-status">
        <span class="chat-status-dot" aria-hidden="true"></span>
        Online now
      </div>
    </div>
    <button class="chat-close" id="chatClose" aria-label="Close chat">
      <svg viewBox="0 0 16 16" fill="none" width="16" height="16">
        <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="chat-messages" id="chatMessages" role="log" aria-live="polite">
  </div>

  <!-- Quick replies -->
  <div class="chat-replies" id="chatReplies" aria-label="Quick reply options">
  </div>

  <!-- Footer note -->
  <div class="chat-footer-note">
    Powered by ADC &mdash; replies are instant
  </div>

</div>

<style>
  /* ── FAB ───────────────────────────────────────────────── */
  .chat-fab {
    position: fixed;
    bottom: 28px; right: 28px;
    width: 60px; height: 60px;
    border-radius: 50%;
    background: var(--navy);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 28px rgba(12,27,58,0.35);
    z-index: 999;
    transition: transform 0.3s var(--ease),
                background 0.3s var(--ease),
                box-shadow 0.3s var(--ease);
    color: var(--white);
  }
  .chat-fab:hover {
    transform: scale(1.08);
    background: var(--amber);
    color: var(--navy);
    box-shadow: 0 8px 36px rgba(245,155,0,0.4);
  }
  .chat-fab.is-open {
    background: var(--amber);
    color: var(--navy);
  }

  .fab-icon { width: 24px; height: 24px; transition: opacity 0.2s, transform 0.2s; }
  .fab-icon--close { position: absolute; opacity: 0; transform: rotate(-90deg) scale(0.8); }
  .chat-fab.is-open .fab-icon--chat  { opacity: 0; transform: rotate(90deg) scale(0.8); }
  .chat-fab.is-open .fab-icon--close { opacity: 1; transform: rotate(0deg) scale(1); }

  /* Notification dot */
  .chat-fab-dot {
    position: absolute;
    top: 6px; right: 6px;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--green);
    border: 2px solid var(--white);
    animation: pulse 2s ease-in-out infinite;
    transition: opacity 0.2s;
  }
  .chat-fab.is-open .chat-fab-dot { opacity: 0; }

  /* ── Panel ─────────────────────────────────────────────── */
  .chat-panel {
    position: fixed;
    bottom: 100px; right: 28px;
    width: 360px;
    max-height: 560px;
    background: var(--white);
    border-radius: 20px;
    border: 1.5px solid var(--mist);
    box-shadow: 0 20px 60px rgba(12,27,58,0.18);
    display: flex; flex-direction: column;
    z-index: 998;
    overflow: hidden;
    /* Hidden state */
    opacity: 0;
    transform: translateY(16px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.3s var(--ease),
                transform 0.3s var(--ease);
  }
  .chat-panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  /* ── Header ────────────────────────────────────────────── */
  .chat-header {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 20px;
    background: var(--navy);
    flex-shrink: 0;
  }
  .chat-header-avatar {
    width: 36px; height: 36px; flex-shrink: 0;
  }
  .chat-header-avatar svg { width: 36px; height: 36px; }
  .chat-header-info { flex: 1; }
  .chat-header-name {
    font-weight: 700; font-size: 14px; color: var(--white);
    line-height: 1.3;
  }
  .chat-header-status {
    display: flex; align-items: center; gap: 5px;
    font-size: 11px; color: rgba(255,255,255,0.5);
  }
  .chat-status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  .chat-close {
    width: 32px; height: 32px;
    border-radius: 8px;
    border: none; cursor: pointer;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .chat-close:hover { background: rgba(255,255,255,0.2); color: var(--white); }

  /* ── Messages ──────────────────────────────────────────── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px 8px;
    display: flex; flex-direction: column; gap: 12px;
    scroll-behavior: smooth;
  }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--mist); border-radius: 2px; }

  /* Bubble */
  .chat-bubble {
    max-width: 82%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 13px; line-height: 1.6;
    animation: msgIn 0.28s var(--ease) both;
  }
  .chat-bubble--bot {
    background: var(--off-white);
    color: var(--navy);
    border-bottom-left-radius: 4px;
    align-self: flex-start;
  }
  .chat-bubble--user {
    background: var(--navy);
    color: var(--white);
    border-bottom-right-radius: 4px;
    align-self: flex-end;
  }

  /* Typing indicator */
  .chat-typing {
    display: flex; align-items: center; gap: 4px;
    padding: 12px 14px;
    background: var(--off-white);
    border-radius: 16px; border-bottom-left-radius: 4px;
    align-self: flex-start;
    animation: msgIn 0.28s var(--ease) both;
  }
  .chat-typing span {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--text-muted);
    animation: typingBounce 1.2s ease-in-out infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.18s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.36s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30%            { transform: translateY(-6px); }
  }

  /* ── Quick replies ─────────────────────────────────────── */
  .chat-replies {
    padding: 8px 16px 12px;
    display: flex; flex-wrap: wrap; gap: 8px;
    flex-shrink: 0;
    min-height: 20px;
  }
  .chat-reply-btn {
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--mist);
    background: var(--white);
    font-size: 12px; font-weight: 600;
    color: var(--navy); cursor: pointer;
    transition: background 0.2s var(--ease),
                border-color 0.2s var(--ease),
                color 0.2s;
    white-space: nowrap;
  }
  .chat-reply-btn:hover {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
  }

  /* ── Footer note ───────────────────────────────────────── */
  .chat-footer-note {
    font-size: 10px; color: var(--text-muted);
    text-align: center;
    padding: 8px 16px 14px;
    border-top: 1px solid var(--mist);
    flex-shrink: 0;
  }

  /* ── Mobile ────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .chat-panel {
      right: 12px; left: 12px;
      width: auto;
      bottom: 92px;
    }
    .chat-fab { bottom: 20px; right: 20px; }
  }
</style>

<script>
  (() => {
    const fab      = document.getElementById('chatFab')!;
    const panel    = document.getElementById('chatPanel')!;
    const closeBtn = document.getElementById('chatClose')!;
    const messages = document.getElementById('chatMessages')!;
    const replies  = document.getElementById('chatReplies')!;

    let isOpen = false;

    /* ── Decision tree ──────────────────────────────────── */
    type Step = {
      bot: string | string[];
      options?: { label: string; next: string }[];
    };

    const tree: Record<string, Step> = {
      start: {
        bot: ["G'day! 👋 I'm the ADC Assistant.", "I can help you find the right package for your business. What best describes where you're at?"],
        options: [
          { label: "🆕 Brand new business", next: "new_biz" },
          { label: "🏢 Established business", next: "established" },
          { label: "🚀 Ready to scale", next: "scale" },
          { label: "💬 Just have a question", next: "question" },
        ],
      },
      new_biz: {
        bot: ["Great — starting fresh! Do you have a website and business email set up yet?"],
        options: [
          { label: "No, need everything", next: "rec_base" },
          { label: "Have some bits, need the rest", next: "rec_base_plus" },
        ],
      },
      established: {
        bot: ["Got it. Are you currently happy with your cybersecurity and IT setup?"],
        options: [
          { label: "Not really — worried about it", next: "rec_fort" },
          { label: "It's okay but could be better", next: "rec_fort" },
          { label: "It's solid — want more", next: "rec_command" },
        ],
      },
      scale: {
        bot: ["Exciting! Sounds like you're ready for Command Centre — our top tier with AI automation, a dedicated account manager, and full ACSC compliance.", "Want me to arrange a free Digital Health Check?"],
        options: [
          { label: "Yes, book me in!", next: "book" },
          { label: "Tell me more first", next: "rec_command" },
        ],
      },
      question: {
        bot: ["Of course — what would you like to know?"],
        options: [
          { label: "What's included in each package?", next: "packages_info" },
          { label: "Is there a lock-in contract?", next: "no_lock" },
          { label: "Where is my data hosted?", next: "data_host" },
          { label: "Talk to a human", next: "human" },
        ],
      },
      rec_base: {
        bot: ["**The Base** ($299/mo) is built for you. We handle your ABN guidance, domain, business email, social handles, and a 3-page website — all set up for you.", "Want to get started?"],
        options: [
          { label: "Yes — get me started!", next: "book" },
          { label: "What's in The Fort?", next: "rec_fort" },
        ],
      },
      rec_base_plus: {
        bot: ["Sounds like **The Base** ($299/mo) would fill the gaps neatly. We audit what you have, fill what's missing, and make sure everything's set up properly."],
        options: [
          { label: "Book a free check", next: "book" },
          { label: "See all packages", next: "packages_info" },
        ],
      },
      rec_fort: {
        bot: ["**The Fort** ($799/mo) is our most popular package — 24/7 monitoring on up to 10 devices, ACSC Essential Eight Phase 1, managed backups, and a 4-hour response SLA.", "It's the security-first choice for established Aussie businesses."],
        options: [
          { label: "Book a free check", next: "book" },
          { label: "What's Command Centre?", next: "rec_command" },
        ],
      },
      rec_command: {
        bot: ["**Command Centre** ($1,799/mo) is our full-stack offering — everything in The Fort plus: a custom AI workflow, full ACSC compliance assessment, SD-WAN failover, quarterly security reviews, and a dedicated account manager."],
        options: [
          { label: "Book a free check", next: "book" },
          { label: "Compare all packages", next: "packages_info" },
        ],
      },
      packages_info: {
        bot: ["You can see full package details in the Pricing section above — The Base ($299), The Fort ($799), and Command Centre ($1,799). All month-to-month, no lock-in."],
        options: [
          { label: "Book a free check", next: "book" },
          { label: "Other question", next: "question" },
        ],
      },
      no_lock: {
        bot: ["No lock-in, ever. All ADC packages are month-to-month. We earn your business every single month."],
        options: [
          { label: "Great — book a free check", next: "book" },
          { label: "Other question", next: "question" },
        ],
      },
      data_host: {
        bot: ["All data is hosted in Australian data centres — Azure Australia East or AWS ap-southeast-2. It never leaves Australian shores. Full data sovereignty guaranteed."],
        options: [
          { label: "Book a free check", next: "book" },
          { label: "Other question", next: "question" },
        ],
      },
      human: {
        bot: ["Absolutely — our team is available on **1300 ADC AUS** or at **hello@australiadigital.center**.", "Or fill in the contact form above and we'll reply within 4 hours."],
        options: [
          { label: "Go to contact form", next: "contact_form" },
          { label: "Start over", next: "start" },
        ],
      },
      book: {
        bot: ["Perfect! 🎉 Head to the contact form above and select your preferred package. We'll confirm your free Digital Health Check within 4 business hours.", "Looking forward to working with you!"],
        options: [
          { label: "Go to contact form", next: "contact_form" },
          { label: "Start over", next: "start" },
        ],
      },
      contact_form: {
        bot: ["Taking you to the contact form now..."],
        options: [],
      },
    };

    /* ── Helpers ─────────────────────────────────────────── */
    function scrollToBottom() {
      messages.scrollTop = messages.scrollHeight;
    }

    function addBubble(text: string, type: 'bot' | 'user') {
      const div = document.createElement('div');
      div.className = `chat-bubble chat-bubble--${type}`;
      // Basic bold support: **text** → <strong>
      div.innerHTML = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      messages.appendChild(div);
      scrollToBottom();
    }

    function showTyping(): Promise<void> {
      return new Promise(resolve => {
        const typing = document.createElement('div');
        typing.className = 'chat-typing';
        typing.innerHTML = '<span></span><span></span><span></span>';
        typing.id = 'typingIndicator';
        messages.appendChild(typing);
        scrollToBottom();
        setTimeout(() => {
          typing.remove();
          resolve();
        }, 900);
      });
    }

    function clearReplies() {
      replies.innerHTML = '';
    }

    async function runStep(key: string, userLabel?: string) {
      clearReplies();

      if (userLabel) {
        addBubble(userLabel, 'user');
      }

      // Special: contact form
      if (key === 'contact_form') {
        await showTyping();
        addBubble("Taking you to the contact form now...", 'bot');
        setTimeout(() => {
          const form = document.getElementById('contact');
          if (form) form.scrollIntoView({ behavior: 'smooth' });
        }, 600);
        setTimeout(() => renderOptions('start'), 1800);
        return;
      }

      const step = tree[key];
      if (!step) return;

      const lines = Array.isArray(step.bot) ? step.bot : [step.bot];

      for (let i = 0; i < lines.length; i++) {
        await showTyping();
        addBubble(lines[i], 'bot');
      }

      renderOptions(key);
    }

    function renderOptions(key: string) {
      const step = tree[key];
      if (!step?.options?.length) return;
      step.options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'chat-reply-btn';
        btn.textContent = opt.label;
        btn.addEventListener('click', () => runStep(opt.next, opt.label));
        replies.appendChild(btn);
      });
    }

    /* ── Open / close ────────────────────────────────────── */
    let started = false;

    function openChat() {
      isOpen = true;
      fab.classList.add('is-open');
      fab.setAttribute('aria-expanded', 'true');
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      if (!started) {
        started = true;
        runStep('start');
      }
    }

    function closeChat() {
      isOpen = false;
      fab.classList.remove('is-open');
      fab.setAttribute('aria-expanded', 'false');
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');
    }

    fab.addEventListener('click', () => isOpen ? closeChat() : openChat());
    closeBtn.addEventListener('click', closeChat);

    // Close on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && isOpen) closeChat();
    });
  })();
</script>
