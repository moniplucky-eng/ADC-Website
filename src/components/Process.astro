---
/* Process.astro
   21st.dev pattern: horizontal numbered step timeline with animated
   gradient connector line. Stacks to vertical on mobile.
*/

const steps = [
  {
    num: "01",
    title: "Free Digital Health Check",
    desc: "We audit your current digital setup and recommend the right package. No pressure, no jargon.",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    num: "02",
    title: "Tailored Proposal",
    desc: "We scope exactly what you need, explain the cost, and confirm your onboarding timeline.",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    num: "03",
    title: "We Build Your Stack",
    desc: "Our team configures everything — domain, email, cloud, security, AI — using proven playbooks.",
    icon: `<svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5"/><path d="M17.5 14v7M14 17.5h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    num: "04",
    title: "Ongoing Partnership",
    desc: "Monthly reports, strategy sessions, and a helpdesk that answers within 4 hours. We grow with you.",
    icon: `<svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<section class="process" id="process">
  <div class="container">

    <!-- Header -->
    <div class="process-header fade-up">
      <span class="section-label">How It Works</span>
      <h2 class="process-heading">
        Up and running in <em>four simple steps.</em>
      </h2>
      <p class="process-sub">
        We've made onboarding frictionless. You'll have a fully operational
        digital stack faster than you think.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="process-steps">
      <!-- Animated connector line (desktop only) -->
      <div class="process-connector" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div
          class="process-step fade-up"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <!-- Number bubble -->
          <div class={`step-num ${i === steps.length - 1 ? 'step-num--final' : ''}`}>
            {step.num}
          </div>

          <!-- Icon -->
          <div class="step-icon" aria-hidden="true">
            <Fragment set:html={step.icon} />
          </div>

          <div class="step-title">{step.title}</div>
          <div class="step-desc">{step.desc}</div>

          <!-- Arrow connector between steps (desktop, all but last) -->
          {i < steps.length - 1 && (
            <div class="step-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- CTA nudge -->
    <div class="process-cta fade-up">
      <a href="#contact" class="btn btn-primary">Start with a Free Audit</a>
    </div>

  </div>
</section>

<style>
  /* ── Section ───────────────────────────────────────────── */
  .process {
    padding: 120px 0;
    background: var(--off-white);
  }

  /* ── Header ────────────────────────────────────────────── */
  .process-header {
    text-align: center;
    margin-bottom: 80px;
  }
  .process-heading {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(30px, 3.5vw, 52px);
    line-height: 1.1; color: var(--navy);
    margin-bottom: 16px;
  }
  .process-heading em { color: var(--amber); font-style: italic; }
  .process-sub {
    font-size: 18px; color: var(--text-muted);
    max-width: 480px; margin: 0 auto; line-height: 1.7;
  }

  /* ── Steps grid ────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  /* Gradient connector line behind the number bubbles */
  .process-connector {
    position: absolute;
    top: 27px; /* half of the 56px bubble */
    left: calc(12.5% + 28px);
    right: calc(12.5% + 28px);
    height: 1px;
    background: linear-gradient(90deg, var(--mist), var(--amber), var(--mist));
    background-size: 200% 100%;
    animation: connectorSlide 3s ease-in-out infinite;
    z-index: 0;
  }
  @keyframes connectorSlide {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Individual step ───────────────────────────────────── */
  .process-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  /* Number bubble */
  .step-num {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid var(--mist);
    font-family: var(--font-display); font-weight: 700;
    font-size: 16px; color: var(--navy);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
    position: relative; z-index: 2;
    transition: background 0.3s var(--ease),
                border-color 0.3s var(--ease),
                color 0.3s var(--ease),
                box-shadow 0.3s var(--ease);
  }
  .process-step:hover .step-num {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
    box-shadow: 0 4px 16px rgba(245,155,0,0.35);
  }
  /* Final step always filled navy */
  .step-num--final {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--white);
  }
  .process-step:hover .step-num--final {
    background: var(--amber);
    border-color: var(--amber);
    color: var(--navy);
  }

  /* Step icon */
  .step-icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    background: var(--white);
    border: 1.5px solid var(--mist);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    transition: background 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .step-icon :global(svg) {
    width: 22px; height: 22px;
    color: var(--navy);
    transition: color 0.3s var(--ease);
  }
  .process-step:hover .step-icon {
    background: var(--navy);
    border-color: var(--navy);
  }
  .process-step:hover .step-icon :global(svg) { color: var(--amber); }

  .step-title {
    font-weight: 700; font-size: 16px;
    color: var(--navy); margin-bottom: 10px;
    line-height: 1.3;
  }
  .step-desc {
    font-size: 14px; color: var(--text-muted);
    line-height: 1.7;
  }

  /* Arrow between steps (desktop) */
  .step-arrow {
    display: none; /* shown via desktop override below */
    position: absolute;
    top: 27px; right: -14px;
    transform: translateY(-50%);
    width: 28px; height: 28px;
    z-index: 3;
    color: var(--amber);
    opacity: 0.5;
  }
  .step-arrow :global(svg) { width: 100%; height: 100%; }

  /* ── CTA ───────────────────────────────────────────────── */
  .process-cta {
    text-align: center;
    margin-top: 64px;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (min-width: 769px) {
    .step-arrow { display: block; }
  }

  @media (max-width: 1024px) {
    .process-steps { grid-template-columns: 1fr 1fr; gap: 48px; }
    .process-connector { display: none; }
    .step-arrow { display: none; }
  }

  @media (max-width: 640px) {
    .process { padding: 80px 0; }
    .process-steps { grid-template-columns: 1fr; gap: 40px; }
    .process-step { align-items: flex-start; text-align: left; flex-direction: row; gap: 20px; padding: 0; }
    .step-num { margin-bottom: 0; flex-shrink: 0; }
    .step-icon { display: none; }
    .step-info { flex: 1; }
  }
</style>
