---
/* Footer.astro
   21st.dev pattern: dark 4-column footer — brand + social left,
   two nav link columns centre, contact right. Hairline top separator.
   Bottom bar: copyright, ABN, legal links.
*/

const serviceLinks = [
  { label: "Online Presence Setup", href: "#services" },
  { label: "ACSC Essential Eight", href: "#services" },
  { label: "Cloud Migration", href: "#services" },
  { label: "24/7 Endpoint Monitoring", href: "#services" },
  { label: "Custom AI Workflows", href: "#services" },
  { label: "Account Management", href: "#services" },
];

const companyLinks = [
  { label: "About ADC", href: "#about" },
  { label: "How It Works", href: "#process" },
  { label: "Cybersecurity", href: "#services" },
  { label: "Pricing", href: "#packages" },
  { label: "Our Team", href: "#team" },
  { label: "Contact", href: "#contact" },
];

const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">

  <!-- Top gradient separator -->
  <div class="footer-separator" aria-hidden="true"></div>

  <div class="container">
    <div class="footer-grid">

      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <!-- Logo lockup -->
        <a href="#" class="footer-logo" aria-label="Australia Digital Center home">
          <svg viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect width="36" height="36" rx="8" fill="#3232C8"/>
            <rect x="7" y="7" width="8" height="8" rx="1.5" fill="#F59B00"/>
            <rect x="21" y="7" width="8" height="8" rx="1.5" fill="#F59B00"/>
            <rect x="7" y="21" width="8" height="8" rx="1.5" fill="#F59B00"/>
            <rect x="21" y="21" width="8" height="8" rx="1.5" fill="rgba(245,155,0,0.4)"/>
            <line x1="15" y1="11" x2="21" y2="11" stroke="white" stroke-width="1.2" stroke-opacity="0.6"/>
            <line x1="11" y1="15" x2="11" y2="21" stroke="white" stroke-width="1.2" stroke-opacity="0.6"/>
            <line x1="25" y1="15" x2="25" y2="21" stroke="white" stroke-width="1.2" stroke-opacity="0.6"/>
            <line x1="15" y1="25" x2="21" y2="25" stroke="white" stroke-width="1.2" stroke-opacity="0.6"/>
          </svg>
          <div class="footer-logo-text">
            <span class="footer-logo-name">Australia Digital</span>
            <span class="footer-logo-sub">Centre</span>
          </div>
        </a>

        <p class="footer-tagline">
          Australian-owned IT and cybersecurity for small businesses ready to grow without the risk.
        </p>

        <!-- ACSC badge -->
        <div class="footer-badge">
          <span class="footer-badge-dot" aria-hidden="true"></span>
          ACSC Essential Eight Aligned
        </div>

        <!-- Socials -->
        <div class="footer-socials" aria-label="Social media links">
          <a href="#" class="footer-social" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="footer-social" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="footer-social" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Services -->
      <div class="footer-col">
        <div class="footer-col-heading">Services</div>
        <ul class="footer-links" role="list">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Company -->
      <div class="footer-col">
        <div class="footer-col-heading">Company</div>
        <ul class="footer-links" role="list">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div class="footer-col">
        <div class="footer-col-heading">Get in Touch</div>
        <div class="footer-contact-items">
          <div class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3-8.6A2 2 0 012.03 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14v2.92z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <a href="tel:1300232287" class="footer-contact-link">1300 ADC AUS</a>
          </div>
          <div class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <a href="mailto:hello@australiadigital.center" class="footer-contact-link">hello@australiadigital.center</a>
          </div>
          <div class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="footer-contact-text">Sydney, NSW<br/>Serving all of Australia</span>
          </div>
        </div>

        <!-- Free audit CTA -->
        <a href="#contact" class="footer-cta">
          Book a Free Audit
          <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <span>© {year} Australia Digital Centre Pty Ltd. All rights reserved.</span>
        <span class="footer-abn">ABN: 00 000 000 000</span>
      </div>
      <div class="footer-bottom-right">
        <a href="#" class="footer-legal-link">Privacy Policy</a>
        <a href="#" class="footer-legal-link">Terms of Service</a>
        <a href="#" class="footer-legal-link">Cookie Policy</a>
      </div>
    </div>

  </div>
</footer>

<style>
  /* ── Footer ────────────────────────────────────────────── */
  .footer {
    background: var(--navy);
    padding: 80px 0 0;
    position: relative;
  }

  /* Amber gradient top separator */
  .footer-separator {
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(245,155,0,0.5) 30%,
      var(--amber) 50%,
      rgba(245,155,0,0.5) 70%,
      transparent 100%
    );
    margin-bottom: 0;
  }

  /* ── Main grid ─────────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 60px;
    padding: 64px 0 56px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  /* ── Col 1: Brand ──────────────────────────────────────── */
  .footer-logo {
    display: inline-flex; align-items: center; gap: 12px;
    text-decoration: none;
    margin-bottom: 20px;
  }
  .footer-logo svg { width: 36px; height: 36px; flex-shrink: 0; }
  .footer-logo-text {
    display: flex; flex-direction: column; line-height: 1.15;
  }
  .footer-logo-name {
    font-family: var(--font-display); font-weight: 800;
    font-size: 14px; color: var(--white);
    letter-spacing: -0.01em;
  }
  .footer-logo-sub {
    font-family: var(--font-display); font-weight: 700;
    font-size: 14px; color: var(--amber);
  }

  .footer-tagline {
    font-size: 13px; color: rgba(255,255,255,0.45);
    line-height: 1.75; margin-bottom: 20px;
    max-width: 280px;
  }

  .footer-badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.55);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-pill);
    padding: 6px 14px;
    margin-bottom: 28px;
    letter-spacing: 0.02em;
  }
  .footer-badge-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .footer-socials {
    display: flex; gap: 10px;
  }
  .footer-social {
    width: 36px; height: 36px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.45);
    transition: background 0.22s var(--ease),
                border-color 0.22s var(--ease),
                color 0.22s var(--ease);
  }
  .footer-social svg { width: 15px; height: 15px; }
  .footer-social:hover {
    background: rgba(245,155,0,0.12);
    border-color: rgba(245,155,0,0.4);
    color: var(--amber);
  }

  /* ── Cols 2 & 3: Links ─────────────────────────────────── */
  .footer-col-heading {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 20px;
  }
  .footer-links {
    display: flex; flex-direction: column; gap: 12px;
    list-style: none; padding: 0; margin: 0;
  }
  .footer-link {
    font-size: 13px; color: rgba(255,255,255,0.55);
    transition: color 0.2s;
    line-height: 1.4;
  }
  .footer-link:hover { color: var(--amber); }

  /* ── Col 4: Contact ────────────────────────────────────── */
  .footer-contact-items {
    display: flex; flex-direction: column; gap: 16px;
    margin-bottom: 28px;
  }
  .footer-contact-item {
    display: flex; align-items: flex-start; gap: 10px;
  }
  .footer-contact-item svg {
    width: 15px; height: 15px; flex-shrink: 0;
    color: var(--amber); stroke: var(--amber);
    margin-top: 1px;
  }
  .footer-contact-link {
    font-size: 13px; color: rgba(255,255,255,0.55);
    transition: color 0.2s;
  }
  .footer-contact-link:hover { color: var(--amber); }
  .footer-contact-text {
    font-size: 13px; color: rgba(255,255,255,0.55);
    line-height: 1.6;
  }

  .footer-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 600;
    color: var(--amber);
    border: 1.5px solid rgba(245,155,0,0.3);
    border-radius: var(--radius-pill);
    padding: 10px 20px;
    transition: background 0.22s var(--ease),
                border-color 0.22s var(--ease),
                gap 0.2s var(--ease);
  }
  .footer-cta:hover {
    background: rgba(245,155,0,0.1);
    border-color: var(--amber);
    gap: 12px;
  }

  /* ── Bottom bar ────────────────────────────────────────── */
  .footer-bottom {
    display: flex; align-items: center;
    justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
    padding: 24px 0 28px;
  }
  .footer-bottom-left {
    display: flex; align-items: center;
    gap: 20px; flex-wrap: wrap;
    font-size: 12px; color: rgba(255,255,255,0.28);
  }
  .footer-abn {
    font-size: 11px; color: rgba(255,255,255,0.2);
  }
  .footer-bottom-right {
    display: flex; align-items: center; gap: 20px;
  }
  .footer-legal-link {
    font-size: 12px; color: rgba(255,255,255,0.28);
    transition: color 0.2s;
  }
  .footer-legal-link:hover { color: rgba(255,255,255,0.6); }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px 40px;
    }
  }
  @media (max-width: 640px) {
    .footer { padding: 60px 0 0; }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 48px 0 40px;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .footer-bottom-right { flex-wrap: wrap; gap: 14px; }
  }
</style>
