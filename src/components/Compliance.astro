---
/* Compliance.astro
   21st.dev pattern: dark feature section with animated SVG blob bg,
   split layout — text left, staggered badge grid right.
*/

const badges = [
  { icon: "🛡️", label: "ACSC Essential Eight" },
  { icon: "🔒", label: "MFA Enforced" },
  { icon: "☁️", label: "AU Data Sovereignty" },
  { icon: "📋", label: "Privacy Act Compliant" },
  { icon: "💾", label: "Encrypted Backups" },
  { icon: "🔍", label: "NGAV Protection" },
];
---

<section class="compliance">

  <!-- Animated blob background -->
  <div class="compliance-blob-wrap" aria-hidden="true">
    <svg class="compliance-blob" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="blobGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%"   stop-color="#F59B00" stop-opacity="0.18"/>
          <stop offset="100%" stop-color="#F59B00" stop-opacity="0.03"/>
        </linearGradient>
      </defs>
      <path fill="url(#blobGrad)">
        <animate attributeName="d" dur="12s" repeatCount="indefinite"
          values="
            M300,80 C420,80 520,160 520,300 C520,440 420,520 300,520 C180,520 80,440 80,300 C80,160 180,80 300,80Z;
            M280,70 C410,50 540,150 530,300 C520,450 410,540 280,530 C150,520 60,430 70,290 C80,150 150,90 280,70Z;
            M320,90 C450,100 530,180 520,310 C510,440 400,530 270,520 C140,510 70,410 80,290 C90,170 190,80 320,90Z;
            M300,80 C420,80 520,160 520,300 C520,440 420,520 300,520 C180,520 80,440 80,300 C80,160 180,80 300,80Z"
        />
      </path>
    </svg>
  </div>

  <!-- Subtle dot grid overlay -->
  <div class="compliance-grid" aria-hidden="true"></div>

  <div class="container">
    <div class="compliance-inner">

      <!-- Left: text -->
      <div class="compliance-text fade-up">
        <span class="section-label section-label--light">Cybersecurity</span>
        <h2 class="compliance-heading">
          Cyber security that meets<br/><em>Australian standards.</em>
        </h2>
        <p class="compliance-body">
          We align every client with the ACSC Essential Eight framework — the
          Australian Government's baseline for protecting businesses from common
          cyber threats. Not optional. Built in from day one.
        </p>

        <!-- Essential Eight mini-list -->
        <ul class="compliance-checklist" role="list">
          {["Application control", "Patch applications", "MFA everywhere", "Restrict admin"].map(item => (
            <li class="checklist-item">
              <span class="checklist-tick" aria-hidden="true">
                <svg viewBox="0 0 14 14" fill="none">
                  <path d="M2.5 7l3 3 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>

        <a href="#contact" class="btn btn-primary compliance-btn">Get ACSC Aligned</a>
      </div>

      <!-- Right: badge grid -->
      <div class="compliance-badges fade-up fade-up--delay" aria-label="Compliance certifications">
        {badges.map((badge, i) => (
          <div
            class="compliance-badge"
            style={`animation-delay: ${0.08 * i}s`}
          >
            <span class="badge-icon" aria-hidden="true">{badge.icon}</span>
            <span class="badge-label">{badge.label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section ───────────────────────────────────────────── */
  .compliance {
    padding: 100px 0;
    background: var(--navy);
    position: relative;
    overflow: hidden;
  }

  /* ── Blob ──────────────────────────────────────────────── */
  .compliance-blob-wrap {
    position: absolute;
    right: -120px; top: -120px;
    width: 500px; height: 500px;
    pointer-events: none; z-index: 0;
  }
  .compliance-blob { width: 100%; height: 100%; }

  /* ── Dot grid ──────────────────────────────────────────── */
  .compliance-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(245,155,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,155,0,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none; z-index: 0;
  }

  /* ── Inner layout ──────────────────────────────────────── */
  .compliance-inner {
    position: relative; z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 80px;
    flex-wrap: wrap;
  }

  /* ── Left text ─────────────────────────────────────────── */
  .compliance-text { flex: 1; min-width: 300px; max-width: 520px; }

  /* Light variant section label */
  .section-label--light { color: var(--amber); }
  .section-label--light::before { background: var(--amber); }

  .compliance-heading {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(28px, 3vw, 46px);
    line-height: 1.15; color: var(--white);
    margin-bottom: 20px;
  }
  .compliance-heading em { color: var(--amber); font-style: italic; }

  .compliance-body {
    font-size: 16px; color: rgba(255,255,255,0.55);
    line-height: 1.75; margin-bottom: 32px;
  }

  /* Checklist */
  .compliance-checklist {
    display: flex; flex-direction: column; gap: 10px;
    margin-bottom: 40px;
  }
  .checklist-item {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.75);
  }
  .checklist-tick {
    width: 22px; height: 22px; border-radius: 50%;
    background: rgba(34,197,94,0.15);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .checklist-tick svg { width: 14px; height: 14px; color: var(--green); }

  .compliance-btn { align-self: flex-start; }

  /* ── Right: badge grid ─────────────────────────────────── */
  .compliance-badges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    flex-shrink: 0;
  }

  .compliance-badge {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.75);
    cursor: default;
    transition: border-color 0.25s var(--ease),
                background 0.25s var(--ease),
                transform 0.25s var(--ease);
    /* stagger-in animation */
    animation: badgeFadeIn 0.5s both;
  }
  .compliance-badge:hover {
    border-color: rgba(245,155,0,0.4);
    background: rgba(245,155,0,0.08);
    transform: translateY(-2px);
  }
  @keyframes badgeFadeIn {
    from { opacity: 0; transform: translateY(12px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .badge-icon { font-size: 20px; flex-shrink: 0; }
  .badge-label { line-height: 1.3; }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .compliance-inner { flex-direction: column; gap: 56px; }
    .compliance-badges { width: 100%; grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .compliance { padding: 72px 0; }
    .compliance-badges { grid-template-columns: 1fr 1fr; }
  }
</style>
